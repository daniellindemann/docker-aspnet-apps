# change the base to an alpine based image to reduce the size of the final image
# the build stage still uses the default SDK image

FROM mcr.microsoft.com/dotnet/runtime-deps:10.0-alpine AS base
WORKDIR /app
EXPOSE 6780

ENV ASPNETCORE_URLS=http://+:6780

USER app

FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:10.0 AS build
# set architecture info for building a self-contained release
ARG TARGETARCH
ARG configuration=Release
ARG runtime=linux-${TARGETARCH}
RUN echo "Building for architecture: ${TARGETARCH} with runtime: ${runtime}"
WORKDIR /src/DockerAspNetApps.SampleApi

