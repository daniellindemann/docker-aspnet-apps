{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Sample API - .NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "01-sampleapi-build",
            "launchSettingsProfile": "http",
            "program": "${workspaceFolder}/src/DockerAspNetApps.SampleApi/bin/Debug/net10.0/DockerAspNetApps.SampleApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/DockerAspNetApps.SampleApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "logging": {
                "moduleLoad": false
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "presentation": {
                "hidden": false,
                "group": "sample-api",
                "order": 1000
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/DockerAspNetApps.SampleApi/bin/Debug/net10.0/DockerAspNetApps.SampleApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/DockerAspNetApps.SampleApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Containers: .NET Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-run: debug",
            "netCore": {
                "appProject": "${workspaceFolder}/src/DockerAspNetApps.SampleApi/DockerAspNetApps.SampleApi.csproj"
            }
        }
    ]
}