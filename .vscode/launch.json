{
    "version": "0.2.0",
    "configurations": [
        {
            // Use IntelliSense to find out which attributes exist for C# debugging
            // Use hover for the description of the existing attributes
            // For further information visit https://github.com/dotnet/vscode-csharp/blob/main/debugger-launchjson.md.
            "name": "Sample API - .NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "01-sampleapi-build",
            "launchSettingsProfile": "http",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/src/DockerAspNetApps.SampleApi/bin/Debug/net10.0/DockerAspNetApps.SampleApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/DockerAspNetApps.SampleApi",
            "stopAtEntry": false,
            // Enable launching a web browser when ASP.NET Core starts. For more information: https://aka.ms/VSCode-CS-LaunchJson-WebBrowser
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "logging": {
                "moduleLoad": false
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "presentation": {
                "hidden": false,
                "group": "sample-api",
                "order": 1000
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "presentation": {
              "hidden": false,
              "group": "z-attach",
              "order": 1000
            }
        }
    ]
}